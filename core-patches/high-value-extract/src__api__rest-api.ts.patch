+async function activateAndroidAdbForPort(
+    req: Request,
+    res: Response,
+    apiModel: ApiModel,
+    proxyPort: number,
+    sessionManager?: SessionController
+): Promise<{
+    success: boolean;
+    proxyPort: number;
+    deviceId: string;
+    activationResult: { success: boolean; metadata?: Record<string, unknown> };
+} | undefined> {
+    const metadata = await apiModel.getInterceptorMetadata('android-adb', 'detailed') as
+        | { deviceIds?: string[] }
+        | undefined;
+    const deviceIds = metadata?.deviceIds ?? [];
+
+    const requestedDeviceId = req.body?.deviceId as string | undefined;
+    const enableSocks = !!req.body?.enableSocks;
+
+    let selectedDeviceId: string | undefined = requestedDeviceId;
+    if (!selectedDeviceId) {
+        if (deviceIds.length === 1) {
+            selectedDeviceId = deviceIds[0];
+        } else if (deviceIds.length > 1) {
+            res.status(409).send({
+                success: false,
+                proxyPort,
+                error: {
+                    message: 'Multiple Android devices are connected: specify deviceId in the request body',
+                    availableDeviceIds: deviceIds
+                }
+            });
+            return;
+        }
+    }
+
+    if (!selectedDeviceId) {
+        res.status(409).send({
+            success: false,
+            proxyPort,
+            error: { message: 'No Android devices are currently connected via ADB' }
+        });
+        return;
+    }
+
+    if (!deviceIds.includes(selectedDeviceId)) {
+        res.status(400).send({
+            success: false,
+            proxyPort,
+            error: {
+                message: `Unknown deviceId '${selectedDeviceId}'`,
+                availableDeviceIds: deviceIds
+            }
+        });
+        return;
+    }
+
+    const activationResult = await apiModel.activateInterceptor(
+        'android-adb',
+        proxyPort,
+        { deviceId: selectedDeviceId, enableSocks }
+    ) as { success: boolean };
+
+    const activationResultWithTrafficFallback = sessionManager
+        ? await withObservedTrafficFallback(activationResult, sessionManager)
+        : activationResult;
+
+    return {
+        success: activationResultWithTrafficFallback.success,
+        proxyPort,
+        deviceId: selectedDeviceId,
+        activationResult: activationResultWithTrafficFallback
+    };
+}
+
+async function withObservedTrafficFallback(
+    activationResult: {
+        success: boolean,
+        metadata?: {
+            reason?: string,
+            connectedStateSource?: string
+            [key: string]: unknown
+        }
+    },
+    sessionManager: SessionController
+) {
+    if (activationResult.success) return activationResult;
+
+    const reason = activationResult.metadata?.reason;
+    if (!reason?.startsWith('timeout_waiting_for_vpn_connected')) {
+        return activationResult;
+    }
+
+    const observedTraffic = await sessionManager.getObservedTrafficSignal?.({
+        waitMs: 4000,
+        pollIntervalMs: 500
+    }) as ObservedTrafficSignal | undefined;
+
+    const metadataText = JSON.stringify(activationResult.metadata ?? {}).toLowerCase();
+    const connectivityEvidence = (
+        metadataText.includes('vpn connected') ||
+        metadataText.includes('vpn:tech.httptoolkit.android.v1') ||
+        metadataText.includes('tun0') ||
+        metadataText.includes('httpproxy [127.0.0.1]') ||
+        metadataText.includes('vpntransportinfo sessionid=http toolkit')
+    );
+
+    if (connectivityEvidence || observedTraffic?.observed) {
+        return {
+            success: true,
+            metadata: {
+                ...activationResult.metadata,
+                reason: connectivityEvidence
+                    ? 'connectivity-evidence-confirms-vpn-active-after-timeout'
+                    : 'data-plane-active-without-explicit-vpn-state',
+                connectedStateSource: connectivityEvidence ? 'dumpsys-connectivity' : observedTraffic?.source,
+                degraded: true,
+                connectionMode: 'degraded-success',
+                warning: connectivityEvidence
+                    ? 'timeout reported, but dumpsys connectivity confirms VPN is connected'
+                    : 'explicit-vpn-state-not-observed',
+                observedTraffic
+            }
+        };
+    }
+
+    return activationResult;
+}
