{
  "enabled": true,
  "targets": [
    {
      "name": "qidian-chapter-pages",
      "methods": ["GET"],
      "urlIncludes": ["qidian.com"],
      "urlRegex": "^https?://(www\\.)?qidian\\.com/.*",
