{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": [
    "src/server.ts",
    "src/qidian/**/*.ts",
    "src/session/**/*.ts",
    "src/android/**/*.ts"
  ],
  "exclude": [
    "migration-assets/**/*",
    "test/**/*"
  ]
}
